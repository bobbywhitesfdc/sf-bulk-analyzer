{
  "name": "sf-bulk-analyzer",
  "description": "Analyze Bulk API V2 and V1 jobs for errors",
  "version": "0.1.4",
  "author": "Bobby White",
  "bin": {
    "sf-bulk-analyzer": "bin/run.js"
  },
  "bugs": "https://github.com/bobbywhitesfdc/sf-bulk-analyzer/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@salesforce/core": "^8.31.0",
    "@salesforce/sf-plugins-core": "^12.2.24",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "@types/sinon": "^21.0.1",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "shx": "^0.3.3",
    "sinon": "^22.0.0",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./classifiers.yaml",
    "./dist",
    "./skill",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/bobbywhitesfdc/sf-bulk-analyzer",
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "sf-bulk-analyzer",
    "dirname": "sf-bulk-analyzer",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {
      "bulk": {
        "description": "Analyze Salesforce Bulk API job failures"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bobbywhitesfdc/sf-bulk-analyzer.git"
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "git add README.md"
  },
  "types": "dist/index.d.ts"
}
